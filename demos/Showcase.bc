          "fontWeight": "bold"
        },
        {
          "id": "bc-widget-923",
          "number": 14,
          "zIndex": 14,
          "visible": true,
          "script": "on('ready', () => every(1000, () => { me._now = Date.now() }))\non('render', () => {\n  const now = new Date(me._now ?? Date.now())\n  const pad = (n) => String(n).padStart(2,'0')\n  return html`\n    <div style=${{\n      display:'flex', alignItems:'center', justifyContent:'center',\n      width:'100%', height:'100%', background:'#101418', color:'#7fdcff',\n      fontFamily:'ui-monospace, monospace', fontSize:'20px', letterSpacing:'3px',\n      borderRadius:'10px', border:'1px solid #2a3a4a',\n    }}>${pad(now.getHours())}:${pad(now.getMinutes())}:${pad(now.getSeconds())}</div>\n  `\n})",
          "Anchors": [
            "left-width",
            "top-height"
          ],
          "name": "Clock",
          "type": "generic",
          "Offsets": [
            392,
            192,
            100,
            42
          ],
          "props": {}
        },
        {
          "id": "bc-widget-924",
          "number": 15,
          "zIndex": 15,
          "visible": true,
          "script": "on('render', () => {\n  const count = me.count ?? 0\n  const Button = (Label,onClick) => html`\n    <button onClick=${onClick} style=${{\n      padding:'4px 12px', fontSize:'14px', cursor:'pointer',\n      borderRadius:'7px', border:'1px solid #ccd', background:'#f6f7fa',\n    }}>${Label}</button>\n  `\n  return html`\n    <div style=${{\n      display:'flex', flexDirection:'column', alignItems:'center', justifyContent:'center',\n      gap:'8px', width:'100%', height:'100%', background:'#fff',\n      border:'2px solid #1d3461', borderRadius:'10px',\n    }}>\n      <div style=${{ fontSize:'9px', color:'#889', textTransform:'uppercase', letterSpacing:'1px' }}>\n        reactive state: ${'me.count = ...'}\n      </div>\n      <div style=${{ fontSize:'34px', fontWeight:'bold', color:'#1d3461', lineHeight:1 }}>${count}</div>\n      <div style=${{ display:'flex', gap:'8px' }}>\n        ${Button('-', () => { me.count = count-1 })}\n        ${Button('+', () => { me.count = count+1 })}\n      </div>\n    </div>\n  `\n})",
          "Anchors": [
            "left-width",
            "top-height"
          ],
          "name": "Counter",
          "type": "generic",
          "Offsets": [
            392,
            192,
            148,
            112
          ],
          "props": {}
        },
        {
          "id": "bc-widget-925",
          "number": 16,
          "zIndex": 16,
          "visible": true,
          "script": "on('touchUp', () => openURL('https://github.com/rozek/browser-card'))",
          "Anchors": [
            "left-width",
            "top-height"
          ],
          "name": "Learn more",
          "type": "button",
          "Offsets": [
            392,
            192,
            268,
            30
          ],
          "variant": "shadow",
          "showName": true,
          "autoHilite": true,
          "enabled": true,
          "sharedHilite": false,
          "text": "Learn more ↗"
        },
        {
          "id": "bc-widget-926",
          "number": 17,
          "zIndex": 17,
          "visible": true,
          "script": "",
          "Anchors": [
            "left-width",
            "top-height"
          ],
          "name": "Footnote",
          "type": "field",
          "Offsets": [
            392,
            192,
            304,
            44
          ],
          "text": "open the designer, hit ✎ Edit -\nand take this card apart!",
          "variant": "transparent",
          "lockText": true,
          "scrolling": false,
          "showLines": false,
          "dontSearch": true,
          "sharedText": false,
          "fontSize": 9,
          "color": "#667"
        },
        {
          "id": "bc-widget-927",
          "number": 18,
          "zIndex": 18,
          "visible": true,
          "script": "on('ready', () => every(40, () => {\n  me._x = (me._x ?? 100) - 0.4\n  if (me._x < -110) { me._x = 100 }\n}))\non('render', () => html`\n  <div style=${{\n    overflow:'hidden', width:'100%', height:'100%', display:'flex', alignItems:'center',\n    background:'#101418', borderRadius:'8px', border:'1px solid #2a3a4a',\n  }}>\n    <div style=${{\n      whiteSpace:'nowrap', transform:`translateX(${me._x ?? 100}%)`,\n      color:'#9ee49e', fontFamily:'ui-monospace, monospace', fontSize:'12px',\n    }}>${props.text ?? 'BrowserCard'}</div>\n  </div>\n`)",
          "Anchors": [
            "left-width",
            "top-height"
          ],
          "name": "Ticker",
          "type": "generic",
          "Offsets": [
            12,
            576,
            412,
            28
          ],
          "props": {
            "text": "+++ BrowserCard +++ decks, cards & widgets +++ scripted with plain JavaScript +++ reactive state via me.* +++ self-cleaning timers +++ dialogs that return values +++ persisted in IndexedDB +++ embeddable everywhere via <bc-deck> +++"
          }
        }
      ]
    }
  ]
