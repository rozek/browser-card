{
  "id": "bc-deck-700",
  "name": "Tutorial",
  "readOnly": false,
  "swipeToAdjacentCard": true,
  "script": "",
  "CardWidth": 600,
  "CardHeight": 450,
  "SnapToGrid": true,
  "GridWidth": 10,
