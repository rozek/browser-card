  "Cards": [
    {
      "Id": "bc-card-701",
      "Name": "Welcome",
      "Color": "#f7f8fb",
      "Alpha": 1,
      "dontSearch": false,
      "Script": "on('ready', () => {\n  const P = Widget('Progress')\n  if (P != null) { P.Value = (me.Card.Index + 1) + ' / ' + CardCount() }\n})",
      "Widgets": [
        {
          "Id": "bc-widget-7001",
          "Number": 1,
          "zIndex": 1,
          "visible": true,
          "Script": "on('ready', () => every(100, () => { me._hue = ((me._hue ?? 210) + 2) % 360 }))\non('render', () => {\n  const hue = me._hue ?? 210\n  return html`\n    <div style=${{\n      width:'100%', height:'100%',\n      display:'flex', flexDirection:'column', alignItems:'center', justifyContent:'center',\n      background:`linear-gradient(120deg, hsl(${hue},65%,28%), hsl(${(hue+70)%360},70%,45%))`,\n      color:'#fff', borderRadius:'0 0 14px 14px',\n    }}>\n      <div style=${{ fontSize:'24px', fontWeight:'bold', letterSpacing:'3px' }}>BrowserCard Tutorial</div>\n      <div style=${{ fontSize:'11px', opacity:0.85 }}>an interactive tour - and itself just an ordinary deck</div>\n    </div>\n  `\n})",
          "Anchors": [
            "left-width",
            "top-height"
          ],
          "Name": "Header",
          "Type": "generic",
          "Offsets": [
            0,
            600,
            0,
            64
          ],
          "Configuration": {},
          "_hue": 116
        },
        {
          "Id": "bc-widget-7002",
          "Number": 2,
          "zIndex": 2,
          "visible": true,
          "Script": "",
          "Anchors": [
            "left-width",
            "top-height"
          ],
          "Name": "Intro",
          "Type": "field",
          "Offsets": [
            40,
            520,
            80,
            100
          ],
          "Value": "Welcome! BrowserCard is a browser-based reinterpretation of HyperCard: you build decks of cards, place widgets on them, and bring everything to life with small JavaScript snippets. No server, no build step - decks live in your browser and can be shared as plain files or complete web apps.",
          "Variant": "transparent",
          "lockText": true,
          "scrolling": false,
          "showLines": false,
          "dontSearch": true,
          "sharedText": false,
          "FontSize": 11,
          "Color": "#334"
        },
