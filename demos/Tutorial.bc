        {
          "id": "bc-widget-7086",
          "number": 86,
          "zIndex": 86,
          "visible": true,
          "script": "on('ready', () => every(1000, () => { me._now = Date.now() }))\non('render', () => {\n  const now = new Date(me._now ?? Date.now())\n  const pad = (n) => String(n).padStart(2,'0')\n  return html`\n    <div style=${{ display:'flex', alignItems:'center', justifyContent:'center',\n      width:'100%', height:'100%', background:'#101418', color:'#7fdcff',\n      fontFamily:'ui-monospace, monospace', fontSize:'18px', letterSpacing:'2px',\n      borderRadius:'10px' }}>${pad(now.getHours())}:${pad(now.getMinutes())}:${pad(now.getSeconds())}</div>`\n})",
          "Anchors": [
            "left-width",
            "top-height"
          ],
          "name": "Clock",
          "type": "generic",
          "Offsets": [
