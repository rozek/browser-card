          ],
          "name": "Explain",
          "type": "field",
          "Offsets": [
            16,
            272,
            46,
            78
          ],
          "text": "custom widgets render themselves with Preact + htm: register on('render') and return an html template. Assignments to me.* re-render the widget AND are saved with the deck:",
          "variant": "transparent",
          "lockText": true,
          "scrolling": false,
          "showLines": false,
          "dontSearch": true,
          "sharedText": false,
          "fontSize": 10,
          "color": "#334"
        },
        {
          "id": "bc-widget-7081",
          "number": 81,
          "zIndex": 81,
          "visible": true,
          "script": "",
          "Anchors": [
            "left-width",
            "top-height"
          ],
          "name": "Code",
          "type": "field",
          "Offsets": [
            16,
            270,
            130,
            150
          ],
          "variant": "rectangle",
          "lockText": true,
          "scrolling": true,
          "showLines": false,
          "dontSearch": true,
          "sharedText": false,
          "fontSize": 9,
          "color": "#0a3069",
          "FontFamily": "ui-monospace, SFMono-Regular, Menlo, monospace",
          "text": "on('render', () => {\n  const count = my.count ?? 0\n  return html`\n    <div>\n      <b>${count}</b>\n      <button onClick=${() => {\n        my.count = count+1\n      }}>+</button>\n    </div>`\n})"
        },
        {
          "id": "bc-widget-7082",
          "number": 82,
          "zIndex": 82,
          "visible": true,
          "script": "",
          "Anchors": [
            "left-width",
            "top-height"
          ],
          "name": "Note",
          "type": "field",
          "Offsets": [
            20,
            270,
            290,
            50
          ],
          "text": "use my.own.* for private state that should neither re-render nor be persisted",
          "variant": "transparent",
          "lockText": true,
          "scrolling": false,
          "showLines": false,
          "dontSearch": true,
          "sharedText": false,
          "fontSize": 9,
          "color": "#8892a6"
        },
        {
          "id": "bc-widget-7083",
          "number": 83,
          "zIndex": 83,
          "visible": true,
          "script": "",
          "Anchors": [
            "left-width",
            "top-height"
          ],
          "name": "Label1",
          "type": "field",
          "Offsets": [
            304,
            272,
            46,
            24
          ],
          "text": "this counter is exactly that widget:",
          "variant": "transparent",
          "lockText": true,
          "scrolling": false,
          "showLines": false,
          "dontSearch": true,
          "sharedText": false,
          "fontSize": 10,
          "color": "#334",
          "fontWeight": "bold"
        },
        {
          "id": "bc-widget-7084",
          "number": 84,
          "zIndex": 84,
          "visible": true,
          "script": "on('render', () => {\n  const count = me.count ?? 0\n  return html`\n    <div style=${{ display:'flex', flexDirection:'column', alignItems:'center',\n      justifyContent:'center', gap:'6px', width:'100%', height:'100%',\n      background:'#fff', border:'2px solid #1d3461', borderRadius:'10px' }}>\n      <div style=${{ fontSize:'30px', fontWeight:'bold', color:'#1d3461', lineHeight:1 }}>${count}</div>\n      <div>\n        <button style=${{ padding:'3px 12px', marginRight:'6px' }} onClick=${() => { me.count = count-1 }}>-</button>\n        <button style=${{ padding:'3px 12px' }} onClick=${() => { me.count = count+1 }}>+</button>\n      </div>\n    </div>`\n})",
          "Anchors": [
            "left-width",
            "top-height"
          ],
          "name": "Counter",
          "type": "generic",
          "Offsets": [
            304,
            272,
            74,
