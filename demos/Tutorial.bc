  "cards": [
    {
      "id": "bc-card-701",
      "name": "Welcome",
      "color": "#f7f8fb",
      "alpha": 1,
      "dontSearch": false,
      "script": "on('ready', () => {\n  const P = widget('Progress')\n  if (P != null) { P.text = cardNumber() + ' / ' + cardCount() }\n})",
      "objects": [
        {
          "id": "bc-widget-7001",
          "number": 1,
          "zIndex": 1,
          "visible": true,
          "script": "on('ready', () => every(100, () => { me._hue = ((me._hue ?? 210) + 2) % 360 }))\non('render', () => {\n  const hue = me._hue ?? 210\n  return html`\n    <div style=${{\n      width:'100%', height:'100%',\n      display:'flex', flexDirection:'column', alignItems:'center', justifyContent:'center',\n      background:`linear-gradient(120deg, hsl(${hue},65%,28%), hsl(${(hue+70)%360},70%,45%))`,\n      color:'#fff', borderRadius:'0 0 14px 14px',\n    }}>\n      <div style=${{ fontSize:'24px', fontWeight:'bold', letterSpacing:'3px' }}>BrowserCard Tutorial</div>\n      <div style=${{ fontSize:'11px', opacity:0.85 }}>an interactive tour - and itself just an ordinary deck</div>\n    </div>\n  `\n})",
          "Anchors": [
            "left-width",
            "top-height"
          ],
          "name": "Header",
          "type": "generic",
          "Offsets": [
            0,
            600,
            0,
            64
          ],
          "Configuration": {},
          "_hue": 248
        },
        {
          "id": "bc-widget-7002",
          "number": 2,
          "zIndex": 2,
          "visible": true,
          "script": "",
          "Anchors": [
            "left-width",
            "top-height"
          ],
          "name": "Intro",
          "type": "field",
          "Offsets": [
            40,
            520,
            80,
            100
          ],
          "text": "Welcome! BrowserCard is a browser-based reinterpretation of HyperCard: you build decks of cards, place widgets on them, and bring everything to life with small JavaScript snippets. No server, no build step - decks live in your browser and can be shared as plain files or complete web apps.",
          "variant": "transparent",
          "lockText": true,
          "scrolling": false,
          "showLines": false,
          "dontSearch": true,
          "sharedText": false,
          "fontSize": 11,
          "color": "#334"
        },
        {
