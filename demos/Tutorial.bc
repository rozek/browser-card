            46,
            60
          ],
          "text": "widgets talk to each other: send('Dice','roll') delivers a message to the script of the dice widget:",
          "variant": "transparent",
          "lockText": true,
          "scrolling": false,
          "showLines": false,
          "dontSearch": true,
