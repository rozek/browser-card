          "visible": true,
          "Script": "",
          "Anchors": [
            "left-width",
            "top-height"
          ],
          "Name": "Steps",
          "Type": "field",
          "Offsets": [
            30,
            540,
            92,
            152
          ],
          "Value": "1.  Export as JSON - the raw deck data, re-importable anywhere (also from a URL)\n\n2.  Export for Embedding… - an HTML snippet with a ready-made <bc-deck> element for any web page\n\n3.  Export as Standalone App… - a complete HTML file: open it anywhere and this very tutorial runs as its own web app, no designer required",
          "Variant": "transparent",
          "lockText": true,
          "scrolling": false,
          "showLines": false,
          "dontSearch": true,
          "sharedText": false,
          "FontSize": 10,
          "Color": "#334"
        },
        {
