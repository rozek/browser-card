            "top-height"
          ],
          "name": "Label1",
          "type": "field",
          "Offsets": [
            304,
            272,
            46,
            40
          ],
          "text": "timers via every() and after() clean up after themselves:",
          "variant": "transparent",
          "lockText": true,
          "scrolling": false,
          "showLines": false,
          "dontSearch": true,
          "sharedText": false,
          "fontSize": 10,
          "color": "#334",
          "fontWeight": "bold"
        },
        {
          "id": "bc-widget-7098",
          "number": 98,
          "zIndex": 98,
          "visible": true,
          "script": "on('ready', () => {\n  me.own.t0 = Date.now()\n  every(100, () => { me._ms = Date.now()-me.own.t0 })\n})\non('render', () => html`\n  <div style=${{ display:'flex', flexDirection:'column', alignItems:'center', justifyContent:'center',\n    width:'100%', height:'100%', background:'#101418', color:'#7fdcff', borderRadius:'10px' }}>\n    <div style=${{ fontSize:'22px', fontFamily:'ui-monospace, monospace' }}>${((me._ms ?? 0)/1000).toFixed(1)}s</div>\n    <div style=${{ fontSize:'9px', opacity:0.7 }}>since you arrived on this card</div>\n  </div>`)",
          "Anchors": [
            "left-width",
            "top-height"
          ],
          "name": "Stopwatch",
          "type": "generic",
          "Offsets": [
            304,
            272,
