          "id": "bc-widget-7126",
          "number": 126,
          "zIndex": 126,
          "visible": true,
          "script": "on('ready', () => every(100, () => { me._hue = ((me._hue ?? 120) + 3) % 360 }))\non('render', () => html`\n  <div style=${{ display:'flex', alignItems:'center', justifyContent:'center',\n    width:'100%', height:'100%', borderRadius:'12px',\n    background:`linear-gradient(120deg, hsl(${me._hue ?? 120},65%,35%), hsl(${((me._hue ?? 120)+80)%360},70%,45%))`,\n    color:'#fff', fontSize:'22px', fontWeight:'bold', letterSpacing:'2px' }}>\n    🎉 you made it!\n  </div>`)",
