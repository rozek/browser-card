          ],
          "name": "Label2",
          "type": "field",
          "Offsets": [
            304,
            272,
            172,
            24
          ],
          "text": "and this clock ticks via every():",
          "variant": "transparent",
          "lockText": true,
          "scrolling": false,
          "showLines": false,
          "dontSearch": true,
          "sharedText": false,
