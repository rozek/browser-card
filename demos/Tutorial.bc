          "fontSize": 9,
          "color": "#0a3069",
          "FontFamily": "ui-monospace, SFMono-Regular, Menlo, monospace",
          "text": "// in the dice widget's script:\non('roll', () => {\n  me._value = 1 + Math.floor(Math.random()*6)\n})"
        },
        {
          "id": "bc-widget-7095",
          "number": 95,
          "zIndex": 95,
          "visible": true,
          "script": "on('touchUp', () => send('Dice','roll'))",
