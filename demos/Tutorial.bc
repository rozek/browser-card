            46,
            40
          ],
          "Value": "decks are plain JSON and travel well. Everything lives in the \"Deck ▾\" menu:",
          "Variant": "transparent",
          "lockText": true,
          "scrolling": false,
          "showLines": false,
          "dontSearch": true,
