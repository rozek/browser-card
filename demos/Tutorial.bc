            46,
            40
          ],
          "text": "decks are plain JSON and travel well. Everything lives in the \"Deck ▾\" menu:",
          "variant": "transparent",
          "lockText": true,
          "scrolling": false,
          "showLines": false,
          "dontSearch": true,
