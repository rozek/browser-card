          ],
          "Name": "Explain",
          "Type": "field",
          "Offsets": [
            16,
            272,
            46,
            78
          ],
          "Value": "custom widgets render themselves with Preact + htm: register on('render') and return an html template. Assignments to me.* re-render the widget AND are saved with the deck:",
          "Variant": "transparent",
          "lockText": true,
          "scrolling": false,
          "showLines": false,
          "dontSearch": true,
          "sharedText": false,
          "FontSize": 10,
          "Color": "#334"
        },
        {
          "Id": "bc-widget-7081",
          "Number": 81,
          "zIndex": 81,
          "visible": true,
          "Script": "",
          "Anchors": [
            "left-width",
            "top-height"
          ],
          "Name": "Code",
          "Type": "field",
          "Offsets": [
            16,
            270,
            130,
            150
          ],
          "Variant": "rectangle",
          "lockText": true,
          "scrolling": true,
          "showLines": false,
          "dontSearch": true,
          "sharedText": false,
          "FontSize": 9,
          "Color": "#0a3069",
          "FontFamily": "ui-monospace, SFMono-Regular, Menlo, monospace",
          "Value": "on('render', () => {\n  const count = my.count ?? 0\n  return html`\n    <div>\n      <b>${count}</b>\n      <button onClick=${() => {\n        my.count = count+1\n      }}>+</button>\n    </div>`\n})"
        },
        {
          "Id": "bc-widget-7082",
          "Number": 82,
          "zIndex": 82,
          "visible": true,
          "Script": "",
          "Anchors": [
            "left-width",
            "top-height"
          ],
          "Name": "Note",
          "Type": "field",
          "Offsets": [
            20,
            270,
            290,
            50
          ],
          "Value": "use my.own.* for private state that should neither re-render nor be persisted",
          "Variant": "transparent",
          "lockText": true,
          "scrolling": false,
          "showLines": false,
          "dontSearch": true,
          "sharedText": false,
          "FontSize": 9,
          "Color": "#8892a6"
        },
        {
          "Id": "bc-widget-7083",
          "Number": 83,
          "zIndex": 83,
          "visible": true,
          "Script": "",
          "Anchors": [
            "left-width",
            "top-height"
          ],
          "Name": "Label1",
          "Type": "field",
          "Offsets": [
            304,
            272,
            46,
            24
          ],
          "Value": "this counter is exactly that widget:",
          "Variant": "transparent",
          "lockText": true,
          "scrolling": false,
          "showLines": false,
          "dontSearch": true,
          "sharedText": false,
          "FontSize": 10,
