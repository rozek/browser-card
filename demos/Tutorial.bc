          "color": "#0a3069",
          "FontFamily": "ui-monospace, SFMono-Regular, Menlo, monospace",
          "text": "<script type=\"module\"\n  src=\"https://rozek.github.io/browser-card/dist/BrowserCard.js\"></script>\n<bc-deck style=\"display:block; width:100%; height:100%\" src=\"…\"></bc-deck>"
        },
